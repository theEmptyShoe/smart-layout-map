[77.5658101882126,12.867786595580867]
]
]);

// ---------------- Cloud Mask ----------------

function maskClouds(image) {

  var qa = image.select("QA_PIXEL");

  var mask =
      qa.bitwiseAnd(1 << 1).eq(0)
      .and(qa.bitwiseAnd(1 << 3).eq(0))
      .and(qa.bitwiseAnd(1 << 4).eq(0))
      .and(qa.bitwiseAnd(1 << 5).eq(0));

  return image.updateMask(mask);
}


// ---------------- Prepare Landsat 5 & 7 ----------------

function prepareL57(image) {

  return image.select(
      ["SR_B3", "SR_B4"],
      ["RED", "NIR"]
    )
    .multiply(0.0000275)
    .add(-0.2);
}


// ---------------- Prepare Landsat 8 & 9 ----------------

function prepareL89(image) {

  return image.select(
      ["SR_B4", "SR_B5"],
      ["RED", "NIR"]
    )
    .multiply(0.0000275)
    .add(-0.2);
}

// ======================================================
// Export one NDVI image per year
// ======================================================

for (var year = 2005; year <= 2026; year++) {

  var start = ee.Date.fromYMD(year,1,1);
  var end = start.advance(1,"year");

  var collection;

  if (year <= 2011) {

    collection = ee.ImageCollection("LANDSAT/LT05/C02/T1_L2")
      .filterBounds(roi)
      .filterDate(start,end)
      .map(maskClouds)
      .map(prepareL57);

  } else if (year === 2012) {

    collection = ee.ImageCollection("LANDSAT/LE07/C02/T1_L2")
      .filterBounds(roi)
      .filterDate(start,end)
      .map(maskClouds)
      .map(prepareL57);

  } else if (year <= 2021) {

    collection = ee.ImageCollection("LANDSAT/LC08/C02/T1_L2")
      .filterBounds(roi)
      .filterDate(start,end)
      .map(maskClouds)
      .map(prepareL89);

  } else {

    collection = ee.ImageCollection("LANDSAT/LC09/C02/T1_L2")
      .filterBounds(roi)
      .filterDate(start,end)
      .map(maskClouds)
      .map(prepareL89);

  }

  var ndvi = collection
      .median()
      .normalizedDifference(["NIR","RED"])
      .rename("NDVI")
      .clip(roi);

  Export.image.toDrive({
    image: ndvi,
    description: "NDVI_" + year,
    fileNamePrefix: "NDVI_" + year,
    folder: "NDVI",
    region: roi,
    scale: 5,
    maxPixels: 1e13,
    fileFormat: "GeoTIFF"
  });
}

Map.centerObject(roi,17);
